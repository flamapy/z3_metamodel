			Sauce {abstract} 
				alternative
					TomatoSauce {Kcal 30, Price 0.00} 
					CreamSauce {Kcal 200, Price 0.50} 
					PestoSauce {Kcal 250, Price 0.80} 
					BiancaSauce {Kcal 60, Price 0.30} 
					SpicyTomatoSauce {Kcal 35, Price 0.20} 
					BarBQSauce {Kcal 180, Price 0.50} 
					ArrabiataSauce {Kcal 40, Price 0.30} 
					BuffaloSauce
					AlfredoSauce
					CurrySauce
					TeriyakiSauce
					TruffleSauce
					PumpkinSauce
					HummusSauce

			Size {abstract} 
				alternative
					Personal {Price 6.00} 
					Small
					Normal {Price 8.00} 
					Medium
					Big {Price 12.00} 
					Large
					Family {Price 16.00} 
					Party {Price 22.00} 
					Giant

			Dough {abstract} 
				alternative
					Neapolitan 
					Sicilian {Price 0.50} 
					Roman {Price 0.30} 
					NewYork {Price 0.40} 
					Chicago {Price 0.70} 
					Sourdough {Price 0.80} 
					WholeGrain
					GlutenFreeDough
					Multigrain
					BlackCharcoal

			Packaging {abstract} 
				alternative
					DineIn 
					TakeAway {Price 0.50} 
					Delivery {Price 2.00} 
					EcoFriendlyBox
					ReusableBox

			BakingMethod {abstract} 
				alternative
					WoodFired {Price 1.00} 
					Electric 
					StoneOven {Price 0.80} 
					ConveyorOven
					CoalOven

			Payment {abstract}
				alternative
					Cash
					CreditCard
					DebitCard
					DigitalWallet
					Crypto
					ApplePay
					GooglePay
					Bitcoin
					MealVoucher

			Temperature {abstract} 
				alternative
					Hot 
					ExtraHot {Price 0.20} 
					Medium 
					Cold 

			CookingTime {abstract} 
				alternative
					Quick {Price 0.50} 
					Standard 
					SlowBaked {Price 0.30} 

constraints
	// --- Restricciones Originales y de 100 features ---
	(CheesyCrust & Sicilian) => Big 
	Neapolitan => (!Salami & !Ham) 
	sum(Price) < 40 // Ajustado por volumen de features 
	Name => len(Name) < 10 & Name == 'Margherita' 
	SpicyLvl >= 1 & SpicyLvl <= 5 
	SpicyLvl == 5 => ExtraHot 
	TotalPrice => TotalPrice > 0.0 
	TableNumber => DineIn 
	CustomerNote => len(CustomerNote) < 100 
	IsVegan => (!Salami & !Ham & !Anchovies & !Pepperoni & !BaconStrips & !ChickenBreast & !TunaDrained & !Shrimps & !Prosciutto) 
	IsVegan => (!CreamSauce & !BarBQSauce & !Mozzarella) 
	Delivery => (Big | Family | Party | Large | Giant) 
	DiscountCoupon => MemberCard 
	BirthdayDiscount => MemberCard 
	LoyaltyPoints => MemberCard 
	Beer => !Delivery 
	PestoSauce => !SpicyLvl 
	ChiliFlakes => (TomatoSauce | BiancaSauce | ArrabiataSauce | SpicyTomatoSauce) 
	Anchovies => (!CreamSauce & !PestoSauce & !BarBQSauce) 
	Family => (TakeAway | Delivery) 
	Party => (TakeAway | Delivery) 
	Personal => !Delivery 
	Roman => !CheesyCrust 
	Quantity >= 1 & Quantity <= 10 
	DeliveryTime => Delivery 
	AllergyNote => len(AllergyNote) < 200 
	PromoCode => len(PromoCode) == 8 
	DiscountRate => (DiscountCoupon | BirthdayDiscount | LoyaltyPoints | ReferralCredit) 
	IsGlutenFree => GlutenFreeCrust 
	IsGlutenFree => (!Neapolitan & !Sicilian & !Chicago & !Sourdough) 
	GlutenFreeCrust => !StuffedCrust 
	Chicago => StuffedCrust 
	Sourdough => !Quick 
	TruffleOil => !SpicyLvl 
	TruffleOil => (!SpicyTomatoSauce & !ArrabiataSauce) 
	WoodFired => (Neapolitan | Roman) 
	StoneOven => !Quick 
	SlowBaked => (WoodFired | StoneOven) 
	Cold => Delivery 
	(SpicyTomatoSauce | ArrabiataSauce) => SpicyLvl 
	(Shrimps | TunaDrained | Anchovies) => !CreamSauce 
	Prosciutto => !SpicyTomatoSauce 
	Pineapple => (!Prosciutto & !Anchovies) 
	IsVegan => (!TiraMisu & !Cannoli & !Gelato) 
	(TiraMisu | Gelato | Cannoli) => !Delivery 
	Wine => DineIn 
	SunDriedTomatoes => !CreamSauce 

	// --- Nuevas Restricciones de Expansión (500 features) ---
	(Beer | Wine | CraftBeer | Cocktail | Margarita | Mojito) => (CustomerAge >= 18)
	DroneDelivery => (Personal | Small)
	DroneDelivery => !Beverage
	IsHalal => (!Salami & !Ham & !BaconStrips & !Chorizo)
	IsLactoseFree => (!Mozzarella & !CreamSauce & !Cheddar & !Brie & !AlfredoSauce)
	Bitcoin => Crypto
	Crypto => DigitalWallet
	TableNumber => !Delivery
	MemberCard => (LoyaltyTier >= 1)
	VIPStatus => MemberCard
	IsEcoFriendly => (EcoFriendlyBox | ReusableBox | DineIn)
	ServiceCharge => DineIn
	ChickenWings => (BuffaloWings | BBQWings)
	IsOrganic => WoodFired
	LoyaltyTier > 5 => DiscountRate > 0.2
	PreparationTime => (Quick => PreparationTime < 15)
	PreparationTime => (SlowBaked => PreparationTime > 30)
	RewardPoints => MemberCard
	StaffID => DineIn
	CaloriesTarget => (ThinCrust & !DoubleCheese)
	AppleJuice => !IsVegan
	WholeGrain => !Quick
	BeyondMeat => IsVegan
	(Party | Giant) => !Personal
	ScheduledDelivery => (DeliveryTime > 60)
	ReferralCode => !PromoCode
	DeliveryDistance > 10.0 => FuelSurcharge
	CarbonFootprint < 2.5 => IsVegan