						alternative
							StandardDelivery
							ExpressDelivery
							ScheduledDelivery
							DroneDelivery
					VehicleType {abstract}
						alternative
							Bicycle
							Motorbike
							Car
							ElectricScooter
					PriorityOrder
					ContactlessDelivery
					LeaveAtDoor
					SignatureRequired
					GiftWrap

		mandatory
			Topping {abstract} 
				or
					Salami {Kcal 462} 
					Ham {Kcal 115} 
					Mozzarella {Kcal 310} 
					Anchovies {Kcal 210, Price 0.50} 
					Pepperoni {Kcal 500, Price 0.80} 
